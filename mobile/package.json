{
  "name": "iebc-voting-mobile",
  "version": "1.0.0",
  "description": "IEBC Voting System Mobile App - React Native",
  "main": "index.js",
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "build:android:debug": "cd android && ./gradlew assembleDebug",
    "build:android:release": "cd android && ./gradlew assembleRelease",
    "build:ios": "xcodebuild -workspace ios/VotingApp.xcworkspace -scheme VotingApp -configuration Release build",
    "lint": "eslint .",
    "test": "jest"
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^6.5.20",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.9.26",
    "axios": "^1.7.2",
    "react": "18.2.0",
    "react-native": "0.74.2",
    "react-native-safe-area-context": "^4.10.1",
    "react-native-screens": "^3.31.1",
    "react-native-svg": "^15.3.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@babel/core": "^7.24.6",
    "@babel/preset-env": "^7.24.6",
    "@babel/runtime": "^7.24.6",
    "@react-native/metro-config": "^0.74.2",
    "@types/react": "^18.3.3",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "metro-react-native-babel-preset": "^0.77.0",
    "typescript": "^5.4.5"
  },
  "private": true
}