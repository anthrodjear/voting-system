# Environment Variables for Smart Contract Deployment

# Private key for deployment (DO NOT COMMIT)
PRIVATE_KEY=your_private_key_here

# RPC URLs
ETHEREUM_MAINNET_RPC=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
SEPOLIA_RPC=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
POLYGON_RPC=https://polygon-rpc.com
MUMBAI_RPC=https://rpc-mumbai.maticvigil.com

# Block Explorers
ETHERSCAN_API_KEY=your_etherscan_api_key
POLYGONSCAN_API_KEY=your_polygonscan_api_key

# Gas Reporting
REPORT_GAS=true
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key

# Contract Addresses (after deployment)
# localhost
LOCALHOST_KEY_MANAGER_ADDRESS=
LOCALHOST_VOTE_CONTRACT_ADDRESS=

# sepolia
SEPOLIA_KEY_MANAGER_ADDRESS=
SEPOLIA_VOTE_CONTRACT_ADDRESS=

# polygonMumbai
MUMBAI_KEY_MANAGER_ADDRESS=
MUMBAI_VOTE_CONTRACT_ADDRESS=

# polygon
POLYGON_KEY_MANAGER_ADDRESS=
POLYGON_VOTE_CONTRACT_ADDRESS=
