# Application
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=voting_system

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=1000

# CORS
CORS_ORIGIN=http://localhost:3001

# Logging
LOG_LEVEL=info

# Blockchain (Hyperledger Besu)
# Private blockchain RPC endpoint
BLOCKCHAIN_RPC_URL=http://localhost:8545
# WebSocket endpoint (optional)
BLOCKCHAIN_WS_URL=ws://localhost:8546
# Authentication token for RPC (optional)
BLOCKCHAIN_AUTH_TOKEN=
# Vote smart contract address
BLOCKCHAIN_VOTE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000001
# Key Manager smart contract address
BLOCKCHAIN_KEY_MANAGER_ADDRESS=0x0000000000000000000000000000000000000002
# Network ID (1337 for local development)
BLOCKCHAIN_NETWORK_ID=1337

# Blockchain Service Account (REQUIRED FOR PRODUCTION)
# Dedicated service account address for transaction signing
BLOCKCHAIN_SERVICE_ACCOUNT=0x0000000000000000000000000000000000000000
# Encrypted private key for service account (AES-256-CBC encrypted)
# Format: iv:encryptedKey:authTag (base64 encoded)
BLOCKCHAIN_PRIVATE_KEY_ENCRYPTED=
# HSM endpoint (optional - use instead of encrypted private key for production)
BLOCKCHAIN_HSM_ENDPOINT=
BLOCKCHAIN_HSM_KEY_ID=
# Key derivation function password (for decrypting private key)
BLOCKCHAIN_KEY_PASSWORD=

# Transaction Settings
# Number of retry attempts for failed transactions
BLOCKCHAIN_TX_RETRIES=3
# Number of block confirmations to wait for
BLOCKCHAIN_TX_CONFIRMATIONS=1
# Gas limit for transactions
BLOCKCHAIN_GAS_LIMIT=500000
# Gas price in Wei (optional, will use network price if empty)
BLOCKCHAIN_GAS_PRICE=
# RPC timeout in milliseconds
BLOCKCHAIN_TIMEOUT=30000
