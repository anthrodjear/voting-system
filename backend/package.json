{
  "name": "voting-system-backend",
  "version": "1.0.0",
  "description": "Blockchain Voting System Backend",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "typeorm": "typeorm-ts-node-commonjs",
    "seed": "ts-node src/database/seeds/seed-cli.ts",
    "seed:all": "ts-node src/database/seeds/seed-cli.ts all",
    "seed:county": "ts-node src/database/seeds/seed-cli.ts county",
    "seed:constituency": "ts-node src/database/seeds/seed-cli.ts constituency",
    "seed:ward": "ts-node src/database/seeds/seed-cli.ts ward",
    "seed:election": "ts-node src/database/seeds/seed-cli.ts election",
    "seed:voter": "ts-node src/database/seeds/seed-cli.ts voter",
    "seed:candidate": "ts-node src/database/seeds/seed-cli.ts candidate",
    "migration:generate": "npm run typeorm -- migration:generate --dataSourcePath src/database/data-source.ts",
    "migration:run": "npm run typeorm -- migration:run --dataSourcePath src/database/data-source.ts",
    "migration:revert": "npm run typeorm -- migration:revert --dataSourcePath src/database/data-source.ts",
    "migration:show": "npm run typeorm -- migration:show --dataSourcePath src/database/data-source.ts",
    "migration:create": "npm run typeorm -- migration:create --dataSourcePath src/database/data-source.ts",
    "seed:run": "ts-node src/database/seeds/run-seeds.ts all",
    "seed:clear": "ts-node src/database/seeds/run-seeds.ts clear"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "argon2": "^0.31.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.19",
    "uuid": "^9.0.1",
    "web3": "^4.16.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@types/passport-jwt": "^4.0.0",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "web3-types": "^1.8.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "path-to-regexp": "^8.4.0",
    "tar": "^7.5.13",
    "picomatch": "^4.0.4",
    "ajv": "^8.18.0"
  }
}
